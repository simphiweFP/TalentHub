{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Api": {
    "Name": "TalentHub API",
    "Description": "Backend foundation for TalentHub.",
    "Version": "1.0"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "TalentHub",
      "Audience": "TalentHub",
      "SigningKey": "change-me-change-me-change-me-change-me",
      "AccessTokenMinutes": 60
    },
    "RefreshTokens": {
      "ExpirationDays": 7,
      "StoreInMemory": true
    },
    "ApiKey": {
      "HeaderName": "X-API-Key",
      "Value": "change-me-api-key",
      "Enabled": true
    }
  },
  "Swagger": {
    "Enabled": true,
    "RoutePrefix": "swagger"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "BackgroundWorkers": {
    "JobSyncInterval": "00:15:00",
    "CompanyRefreshInterval": "01:00:00",
    "ExpiredDataCleanupInterval": "06:00:00",
    "RetryCount": 3,
    "RetryDelayMilliseconds": 1000,
    "SearchHistoryRetentionDays": 30,
    "AuditLogRetentionDays": 90,
    "ClosedJobRetentionDays": 30
  },
  "Greenhouse": {
    "BaseUrl": "https://boards.greenhouse.io",
    "ApiPath": "/api/v1",
    "DefaultPageSize": 20
  },
  "Lever": {
    "BaseUrl": "https://jobs.lever.co",
    "ApiPath": "/api/v1",
    "DefaultPageSize": 20
  },
  "AllowedHosts": "*"
}
