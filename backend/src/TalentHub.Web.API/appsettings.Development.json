{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "Authentication": {
    "ApiKey": {
      "Enabled": true
    }
  },
  "Swagger": {
    "Enabled": true
  },
  "BackgroundWorkers": {
    "JobSyncInterval": "00:05:00",
    "CompanyRefreshInterval": "00:30:00",
    "ExpiredDataCleanupInterval": "02:00:00"
  }
}
